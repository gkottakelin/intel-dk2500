# Copy this file to .env and replace the placeholder. Never commit the real key.
MOONSHOT_API_KEY=replace_with_your_kimi_api_key

# Optional overrides; config/ai_agent.json already contains these defaults.
JETARM_API_BASE_URL=https://api.moonshot.cn/v1
JETARM_API_MODEL=kimi-k2.6

# Arm tools are disabled by default. Test with dry-run before using hardware.
JETARM_ARM_MODE=off
# JETARM_ARM_PORT=/dev/serial/by-id/usb-your-device
JETARM_ARM_MAX_DISTANCE_CM=10

<?xml version="1.0"?>
<robot name="jetarm_joint_gui" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Minimal slider model for joint_state_publisher_gui.
       J1-J5 use URDF/model angles. J6 uses the real raw gripper position
       range 0..1000 so the GUI matches the bus-servo convention. -->
  <xacro:property name="base_to_joint2" value="0.105"/>
  <xacro:property name="link_23" value="0.13"/>
  <xacro:property name="link_34" value="0.13"/>
  <xacro:property name="link_45" value="0.06"/>
  <xacro:property name="link_5_tcp" value="0.102"/>

  <xacro:property name="j1_limit" value="2.0943951023931953"/>
  <xacro:property name="j2_lower" value="0.0"/>
  <xacro:property name="j2_upper" value="1.5707963267948966"/>
  <xacro:property name="j3_limit" value="2.0943951023931953"/>
  <xacro:property name="j4_lower" value="-2.0943951023931953"/>
  <xacro:property name="j4_upper" value="2.0943951023931953"/>
  <xacro:property name="j5_limit" value="1.0471975511965976"/>
  <xacro:property name="j6_raw_max_position" value="1000.0"/>

  <link name="base_link"/>

  <joint name="joint1_base_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="base_yaw_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-j1_limit}" upper="${j1_limit}" effort="8.0" velocity="1.0"/>
  </joint>
  <link name="base_yaw_link"/>

  <joint name="joint2_shoulder_pitch" type="revolute">
    <parent link="base_yaw_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 ${base_to_joint2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${j2_lower}" upper="${j2_upper}" effort="12.0" velocity="1.0"/>
  </joint>
  <link name="upper_arm_link"/>

  <joint name="joint3_elbow_pitch" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 ${link_23}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-j3_limit}" upper="${j3_limit}" effort="8.0" velocity="1.0"/>
  </joint>
  <link name="forearm_link"/>

  <joint name="joint4_wrist_pitch" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0 0 ${link_34}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${j4_lower}" upper="${j4_upper}" effort="5.0" velocity="1.0"/>
  </joint>
  <link name="wrist_pitch_link"/>

  <joint name="joint5_wrist_roll" type="revolute">
    <parent link="wrist_pitch_link"/>
    <child link="tool_roll_link"/>
    <origin xyz="0 0 ${link_45}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-j5_limit}" upper="${j5_limit}" effort="4.0" velocity="1.0"/>
  </joint>
  <link name="tool_roll_link"/>

  <joint name="tcp_fixed_joint" type="fixed">
    <parent link="tool_roll_link"/>
    <child link="tcp_link"/>
    <origin xyz="0 0 ${link_5_tcp}" rpy="0 0 0"/>
  </joint>
  <link name="tcp_link"/>

  <joint name="joint6_gripper" type="revolute">
    <parent link="tcp_link"/>
    <child link="joint6_raw_slider_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="${j6_raw_max_position}" effort="2.0" velocity="1000.0"/>
  </joint>
  <link name="joint6_raw_slider_link"/>
</robot>

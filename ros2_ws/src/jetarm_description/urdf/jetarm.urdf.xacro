<?xml version="1.0"?>
<robot name="jetarm" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- Initial measured model. Units are meters and radians. -->
  <xacro:property name="base_to_joint2" value="0.105"/>
  <xacro:property name="link_23" value="0.13"/>
  <xacro:property name="link_34" value="0.13"/>
  <xacro:property name="link_45" value="0.06"/>
  <xacro:property name="link_5_tcp" value="0.102"/>

  <xacro:property name="j1_limit" value="2.0943951023931953"/>
  <xacro:property name="j2_lower" value="0.0"/>
  <xacro:property name="j2_upper" value="1.5707963267948966"/>
  <xacro:property name="j3_limit" value="2.0943951023931953"/>
  <xacro:property name="j4_lower" value="-2.0943951023931953"/>
  <xacro:property name="j4_upper" value="2.0943951023931953"/>
  <xacro:property name="j5_limit" value="1.0471975511965976"/>
  <xacro:property name="j6_visual_closed_angle" value="1.5707963267948966"/>
  <xacro:property name="j6_visual_open_angle" value="1.5707963267948966"/>
  <xacro:property name="gripper_arm_length" value="0.102"/>

  <material name="jetarm_green">
    <color rgba="0.0 0.55 0.18 1.0"/>
  </material>
  <material name="jetarm_dark">
    <color rgba="0.02 0.02 0.025 1.0"/>
  </material>
  <material name="joint_black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="tcp_red">
    <color rgba="0.85 0.05 0.02 1.0"/>
  </material>
  <material name="finger_rubber">
    <color rgba="0.015 0.015 0.018 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.085" length="0.03"/>
      </geometry>
      <material name="jetarm_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.085" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint1_base_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="base_yaw_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-j1_limit}" upper="${j1_limit}" effort="8.0" velocity="1.0"/>
  </joint>

  <link name="base_yaw_link">
    <visual>
      <origin xyz="0 0 ${base_to_joint2 / 2.0}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="${base_to_joint2}"/>
      </geometry>
      <material name="jetarm_green"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${base_to_joint2}" rpy="0 1.5707963267948966 0"/>
      <geometry>
        <cylinder radius="0.032" length="0.06"/>
      </geometry>
      <material name="joint_black"/>
    </visual>
  </link>

  <joint name="joint2_shoulder_pitch" type="revolute">
    <parent link="base_yaw_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 ${base_to_joint2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${j2_lower}" upper="${j2_upper}" effort="12.0" velocity="1.0"/>
  </joint>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0 0 ${link_23 / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="0.035 0.03 ${link_23}"/>
      </geometry>
      <material name="jetarm_green"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${link_23}" rpy="0 1.5707963267948966 0"/>
      <geometry>
        <cylinder radius="0.027" length="0.055"/>
      </geometry>
      <material name="joint_black"/>
    </visual>
  </link>

  <joint name="joint3_elbow_pitch" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 ${link_23}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-j3_limit}" upper="${j3_limit}" effort="8.0" velocity="1.0"/>
  </joint>

  <link name="forearm_link">
    <visual>
      <origin xyz="0 0 ${link_34 / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="0.032 0.026 ${link_34}"/>
      </geometry>
      <material name="jetarm_green"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${link_34}" rpy="0 1.5707963267948966 0"/>
      <geometry>
        <cylinder radius="0.024" length="0.052"/>
      </geometry>
      <material name="joint_black"/>
    </visual>
  </link>

  <joint name="joint4_wrist_pitch" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0 0 ${link_34}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${j4_lower}" upper="${j4_upper}" effort="5.0" velocity="1.0"/>
  </joint>

  <link name="wrist_pitch_link">
    <visual>
      <origin xyz="0 0 ${link_45 / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.024 ${link_45}"/>
      </geometry>
      <material name="jetarm_green"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${link_45}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.026"/>
      </geometry>
      <material name="joint_black"/>
    </visual>
  </link>

  <joint name="joint5_wrist_roll" type="revolute">
    <parent link="wrist_pitch_link"/>
    <child link="tool_roll_link"/>
    <origin xyz="0 0 ${link_45}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-j5_limit}" upper="${j5_limit}" effort="4.0" velocity="1.0"/>
  </joint>

  <link name="tool_roll_link">
    <visual>
      <origin xyz="0 0 0.012" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.017" length="0.024"/>
      </geometry>
      <material name="jetarm_dark"/>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.014"/>
      </geometry>
      <material name="jetarm_dark"/>
    </visual>
  </link>

  <joint name="tcp_fixed_joint" type="fixed">
    <parent link="tool_roll_link"/>
    <child link="tcp_link"/>
    <origin xyz="0 0 ${link_5_tcp}" rpy="0 0 0"/>
  </joint>

  <link name="tcp_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.012"/>
      </geometry>
      <material name="tcp_red"/>
    </visual>
    <visual>
      <origin xyz="0 0 -0.035" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.06 0.012"/>
      </geometry>
      <material name="joint_black"/>
    </visual>
  </link>

  <!--
    J6 is one gripper command. joint_state_mapper.py maps the raw 0..1000
    servo position to this visual angle: 0 is fully open, 700 is closed, and
    700..1000 stays geometrically closed while representing more grip force.
    The opposite arm is a mimic joint, not a second control parameter.
  -->
  <joint name="joint6_gripper" type="revolute">
    <parent link="tool_roll_link"/>
    <child link="left_gripper_finger_link"/>
    <origin xyz="0 0 0" rpy="${-j6_visual_open_angle} 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="${j6_visual_closed_angle}" effort="2.0" velocity="0.5"/>
  </joint>

  <link name="left_gripper_finger_link">
    <visual>
      <origin xyz="0 0 ${gripper_arm_length / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="0.010 0.010 ${gripper_arm_length}"/>
      </geometry>
      <material name="joint_black"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${gripper_arm_length}" rpy="0 0 0"/>
      <geometry>
        <box size="0.016 0.014 0.020"/>
      </geometry>
      <material name="finger_rubber"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${gripper_arm_length / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="0.010 0.010 ${gripper_arm_length}"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint6_gripper_mimic" type="revolute">
    <parent link="tool_roll_link"/>
    <child link="right_gripper_finger_link"/>
    <origin xyz="0 0 0" rpy="${j6_visual_open_angle} 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="${-j6_visual_closed_angle}" upper="0.0" effort="2.0" velocity="0.5"/>
    <mimic joint="joint6_gripper" multiplier="-1.0" offset="0.0"/>
  </joint>

  <link name="right_gripper_finger_link">
    <visual>
      <origin xyz="0 0 ${gripper_arm_length / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="0.010 0.010 ${gripper_arm_length}"/>
      </geometry>
      <material name="joint_black"/>
    </visual>
    <visual>
      <origin xyz="0 0 ${gripper_arm_length}" rpy="0 0 0"/>
      <geometry>
        <box size="0.016 0.014 0.020"/>
      </geometry>
      <material name="finger_rubber"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${gripper_arm_length / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="0.010 0.010 ${gripper_arm_length}"/>
      </geometry>
    </collision>
  </link>
</robot>

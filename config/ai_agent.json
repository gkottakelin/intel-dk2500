{
  "api": {
    "provider": "openai_compatible",
    "base_url": "https://api.moonshot.cn/v1",
    "model": "kimi-k2.6",
    "api_key_env": "MOONSHOT_API_KEY",
    "timeout_s": 60,
    "extra_body": {
      "thinking": {
        "type": "disabled"
      }
    }
  },
  "conversation": {
    "temperature": null,
    "max_tokens": 2048,
    "max_history_messages": 40,
    "system_prompt": "你是JetArm机械臂项目的AI助手。当前只允许普通文本对话和显式注册的安全测试工具，不要声称已经看到相机画面，也不要声称已经控制机械臂。回答应准确、简洁；如果缺少执行任务所需的信息，应明确说明。"
  }
}
